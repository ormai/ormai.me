server {
    if ($http_user_agent ~* "(AdsBot-Google|Amazonbot|anthropic-ai|Applebot|Applebot-Extended|AwarioRssBot|AwarioSmartBot|Bytespider|CCBot|ChatGPT-User|ClaudeBot|Claude-Web|cohere-ai|DataForSeoBot|Diffbot|FacebookBot|FriendlyCrawler|Google-Extended|GoogleOther|GPTBot|img2dataset|ImagesiftBot|magpie-crawler|Meltwater|omgili|omgilibot|peer39_crawler|peer39_crawler/1.0|PerplexityBot|PiplBot|scoop.it|Seekr|YouBot)"){
        return 403;
    }

    server_name git.ormai.me;
    http2 on;
    
    location / {
        # https://her.esy.fun/posts/0031-how-i-protect-my-forgejo-instance-from-ai-web-crawlers/index.html
        if ($http_user_agent ~* "git/|git-lfs/") {
            set $bypass_cookie 1;
        }
        if ($request_uri ~ ^/api/actions/runner\.v1\.RunnerService/) {
            set $bypass_cookie 1;
        }
        if ($cookie_crawl_away_bad_bot = "1") {
            set $bypass_cookie 1;
        }
        if ($bypass_cookie != 1) {
            add_header Content-Type text/html always;
            return 418 '<script>document.cookie = "crawl_away_bad_bot=1; Path=/;"; window.location.reload();</script>';
        }

        proxy_pass http://127.0.0.1:3000;
        add_header X-Frame-Options SAMEORIGIN;
        add_header X-XSS-Protection "1; mode=block";
        proxy_redirect off;
        proxy_buffering off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_read_timeout 90;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/git.ormai.me/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/git.ormai.me/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($http_user_agent ~* "(AdsBot-Google|Amazonbot|anthropic-ai|Applebot|Applebot-Extended|AwarioRssBot|AwarioSmartBot|Bytespider|CCBot|ChatGPT-User|ClaudeBot|Claude-Web|cohere-ai|DataForSeoBot|Diffbot|FacebookBot|FriendlyCrawler|Google-Extended|GoogleOther|GPTBot|img2dataset|ImagesiftBot|magpie-crawler|Meltwater|omgili|omgilibot|peer39_crawler|peer39_crawler/1.0|PerplexityBot|PiplBot|scoop.it|Seekr|YouBot)"){
        return 403;
    }

    if ($host = git.ormai.me) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    server_name git.ormai.me;
    listen 80;
    return 404; # managed by Certbot
}
